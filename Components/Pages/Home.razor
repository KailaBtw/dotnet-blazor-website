@page "/"
@using MudBlazor

<PageTitle>Home</PageTitle>

<div>@((MarkupString)product.Name)</div>
<MudBreadcrumbs Items="_items"></MudBreadcrumbs>
<p>@product.Description</p>
<!-- <img src="@product.ImageUrl" alt="(Blazor Logo)" /> -->


<!-- Carousel: max-width matches largest image so it doesn't stretch edge-to-edge -->
<div style="max-width: 580px; margin: 0 auto;">
    <MudCarousel Class="mud-width-full" @ref="_carousel" ItemsSource="@_carouselImages" @bind-SelectedIndex="selectedIndex" Style="height:280px;" ShowArrows="true" ShowBullets="true" EnableSwipeGesture="true" AutoCycle="true">
        <ItemTemplate>
            <div class="d-flex align-center justify-center" style="height:100%; background:#fff;">
                <img src="@context.ImageUrl" alt="@context.AltText" style="max-height:100%; max-width:100%; object-fit:contain;" />
            </div>
        </ItemTemplate>
    </MudCarousel>
</div>


@code {
    // our C# code lives here
    private string name = "<h1>Home Page</h1>";
    private Product product = default!;
    private MudCarousel<CarouselSlide> _carousel = default!;
    private bool _arrows = true;
    private bool _bullets = true;
    private bool _enableSwipeGesture = true;
    private bool _autocycle = true;
    private IList<CarouselSlide> _carouselImages = new List<CarouselSlide>()
    {
        new("https://images.unsplash.com/photo-1763730731856-c5ddc7824c75?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D", 
        "Cityscape"),
        new("https://images.unsplash.com/photo-1764100039100-9c62823c0f5c?q=80&w=2058&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D", 
        "Mountains"),
        new("https://plus.unsplash.com/premium_photo-1767635217952-1b6c2ee97cd3?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxleHBsb3JlLWZlZWR8MTZ8fHxlbnwwfHx8fHw%3D", 
        "Fog"),
    };
    private int selectedIndex = 0;

    private List<BreadcrumbItem> _items =
    [
        new("Home", href: "#", icon: Icons.Material.Filled.Home, disabled: true),
        //new("Test Page", href: null, disabled: true, icon: Icons.Material.Filled.Pageview),
    ];
    
    protected override void OnInitialized() 
    {
        product = new Product { 
            Name = name,
            Description = "This is a test page I wrote to become familiar with Blazor layouts and using material components (Mudblazor).",
            ImageUrl = "https://damienbod.com/wp-content/uploads/2024/01/brandblazor_nohalo_1000x.png?w=1000"
        };
    }

    public class Product
    {
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string ImageUrl { get; set; } = string.Empty;
    }

    private sealed record CarouselSlide(string ImageUrl, string AltText);

    private async Task AddAsync()
    {
        var n = _carouselImages.Count + 1;
        _carouselImages.Add(new CarouselSlide($"https://via.placeholder.com/600x280?text=Slide+{n}", $"Carousel slide {n}"));
        await Task.Delay(1);
        _carousel.MoveTo(_carouselImages.Count - 1);
    }

    private async Task DeleteAsync(int index)
    {
        if (_carouselImages.Any())
        {
            _carouselImages.RemoveAt(index);
            await Task.Delay(1);
            _carousel.MoveTo(System.Math.Max(System.Math.Min(index, _carouselImages.Count - 1), 0));
        }
    }
}
